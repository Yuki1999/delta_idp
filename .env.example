# Delta IDP — required secrets & config (copy to a real env; NEVER commit real values)
#
# On the server, export these before `pm2 start ecosystem.config.cjs`, e.g.:
#   set -a; source /home/sip-telecom/Services/delta_idp/.env; set +a
#   pm2 start ecosystem.config.cjs

# MinerU (https://mineru.net) — document parsing API token
MINERU_API_KEY=

# DashScope / Bailian — Qwen API key (starts with sk-)
DASHSCOPE_API_KEY=

# ── API authentication (HTTP Basic on the backend) ──
# When BASIC_AUTH_PASS is set, every endpoint except /api/health requires these
# credentials. Leave BASIC_AUTH_PASS empty to DISABLE auth (not recommended).
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=

# ── CORS ──
# Comma-separated list of allowed cross-origin callers. The SPA is served
# same-origin so this can stay empty. Never use "*".
# ALLOWED_ORIGINS=https://your-frontend.example.com

# Optional model overrides
# QWEN_MODEL=qwen-vl-max          # backend (vision) default
# QWEN_MODEL_ID=qwen3.6-27b       # agent-pi chat/extraction model
# QWEN_MODEL_ID_JSON=qwen-plus    # agent-pi read_invoice/read_packing_list JSON model
