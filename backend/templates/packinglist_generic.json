{
  "name": "装箱单通用模板",
  "document_type": "packing_list",
  "vendor": "generic",
  "description": "通用装箱单报关信息提取模板，覆盖物流、包装、重量体积等字段",
  "extraction_fields": [
    { "name": "invoice_no", "label": "对应发票号码", "description": "关联的发票号", "search_patterns": ["No. & date of invoice", "Invoice No"], "data_type": "string" },
    { "name": "shipper", "label": "发货单位", "description": "发货方全称", "search_patterns": ["Shipper/Export", "Shipper", "Exporter"], "data_type": "string" },
    { "name": "consignee", "label": "收货单位", "description": "收货方全称", "search_patterns": ["For Account & Risk", "Consignee", "Buyer"], "data_type": "string" },
    { "name": "notify_party", "label": "通知方", "description": "通知方", "search_patterns": ["Notify party", "Notify"], "data_type": "string" },
    { "name": "port_of_loading", "label": "装货港/起运地", "description": "装货港", "search_patterns": ["Port of loading", "起运地", "装货港"], "data_type": "string" },
    { "name": "final_destination", "label": "目的地/最终目的国", "description": "最终目的地", "search_patterns": ["Final destination", "目的地"], "data_type": "string" },
    { "name": "carrier", "label": "运输方式", "description": "承运人/运输方式", "search_patterns": ["Carrier", "运输方式"], "data_type": "string" },
    { "name": "total_packages", "label": "件数", "description": "总包装件数", "search_patterns": ["Total Packages", "件数", "No. of PKGS", "Total PKGS", "CARTON"], "data_type": "number" },
    { "name": "gross_weight", "label": "毛重", "description": "总毛重 kg，保留3位小数", "search_patterns": ["Gross Weight", "G.W.", "毛重", "Gross Wt", "GROSS"], "data_type": "number" },
    { "name": "net_weight", "label": "净重", "description": "总净重 kg，保留3位小数", "search_patterns": ["Net Weight", "N.W.", "净重", "Net Wt", "NET"], "data_type": "number" },
    { "name": "measurement", "label": "体积", "description": "总体积 CBM，保留4位小数", "search_patterns": ["Measurement", "CBM", "体积", "Meas"], "data_type": "number" },
    { "name": "packing_type", "label": "包装方式", "description": "纸箱/木托/裸装等", "search_patterns": ["Carton", "Pallet", "Box", "包装", "PKGS"], "data_type": "string" },
    { "name": "country_of_origin", "label": "原产国", "description": "货物原产国", "search_patterns": ["made in", "Country of Origin", "原产国", "Origin"], "data_type": "string" },
    { "name": "final_destination_country", "label": "最终目的国", "description": "最终到达国家", "search_patterns": ["Final Destination", "最终目的国"], "data_type": "string" },
    { "name": "incoterms", "label": "贸易术语", "description": "FOB/CIF/DAP等", "search_patterns": ["DAP", "FOB", "CIF", "EXW", "FCA"], "data_type": "string" }
  ],
  "line_item_fields": [
    { "name": "item_no", "label": "序号" },
    { "name": "po_no", "label": "订单号" },
    { "name": "part_no", "label": "产品编号" },
    { "name": "samsung_pn", "label": "三星料号" },
    { "name": "description", "label": "品名" },
    { "name": "quantity", "label": "申报数量" },
    { "name": "unit", "label": "单位" },
    { "name": "net_weight", "label": "净重" },
    { "name": "gross_weight", "label": "毛重" },
    { "name": "carton_no", "label": "箱号" }
  ]
}
