{
  "name": "报关单综合抽取模板",
  "id": "customs_declaration",
  "description": "报关单综合信息抽取模板，适用于整套报关资料（客户邮件+商业发票+装箱单+业务说明），通过交叉引用多份文件提取22个报关字段。",
  "prompt_config": {
    "role": "专业报关员",
    "doc_types": "客户委托邮件、业务说明、商业发票(Invoice)、装箱单(Packing List)",
    "rules": [
      {
        "key": "primary_source_iv",
        "label": "以发票(IV)为主数据源，保留发票中每一行明细的所有属性列",
        "enabled": true
      },
      {
        "key": "cross_validate",
        "label": "装箱单(PL)用于校验数量、件数，补充发票缺失信息",
        "enabled": true
      },
      {
        "key": "iv_priority_conflict",
        "label": "发票与装箱单数据不一致时，以发票为准并在备注中标注差异",
        "enabled": true
      },
      {
        "key": "no_truncation",
        "label": "绝对禁止省略、合并、截断明细行或使用'...'代替",
        "enabled": true
      },
      {
        "key": "qty_total",
        "label": "申报数量字段必须填写所有明细行数量的合计总数",
        "enabled": true
      },
      {
        "key": "confidence",
        "label": "标注置信度（高/中/低）",
        "enabled": true
      },
      {
        "key": "null_missing",
        "label": "缺失字段填 null，不得编造",
        "enabled": true
      },
      {
        "key": "custom_1781166540257",
        "label": "优先用发票和装箱单里的原始描述，不要翻译和改写",
        "enabled": true
      }
    ],
    "format": {
      "weight_decimals": 3,
      "volume_decimals": 4,
      "amount_decimals": 2
    },
    "additional_notes": ""
  },
  "system_prompt": "你是一位专业报关员，擅长从国际物流单据中提取结构化信息。",
  "prompt_template": "",
